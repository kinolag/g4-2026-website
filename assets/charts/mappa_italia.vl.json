        {
          "data": {
            "name": "loc"
          },
          "transform": [
            {
              "filter": {
                "param": "sel",
                "empty": false
              }
            },
            {
              "calculate": "'LOCALITÀ DI RIPRESA'",
              "as": "_c"
            }
          ],
          "mark": {
            "type": "text",
            "align": "left",
            "fontSize": 11,
            "fontWeight": "bold",
            "color": "#94a3b8",
            "limit": 250
          },
          "encoding": {
            "x": {
              "value": 18
            },
            "y": {
              "value": 140
            },
            "text": {
              "field": "_c",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "name": "loc"
          },
          "transform": [
            {
              "filter": {
                "param": "sel",
                "empty": false
              }
            },
            {
              "window": [
                {
                  "op": "row_number",
                  "as": "idx"
                }
              ],
              "sort": [
                {
                  "field": "localita",
                  "order": "ascending"
                }
              ]
            },
            {
              "calculate": "'•  ' + datum.localita",
              "as": "bullet"
            }
          ],
          "mark": {
            "type": "text",
            "align": "left",
            "fontSize": 14,
            "color": "#2b6cb0"
          },
          "encoding": {
            "x": {
              "value": 18
            },
            "y": {
              "field": "idx",
              "type": "quantitative",
              "scale": {
                "domain": [
                  0,
                  10
                ],
                "range": [
                  162,
                  482
                ]
              },
              "axis": null
            },
            "text": {
              "field": "bullet",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "name": "loc"
          },
          "transform": [
            {
              "filter": {
                "param": "sel",
                "empty": false
              }
            },
            {
              "calculate": "'→  Vai alla pagina del cluster'",
              "as": "_l"
            }
          ],
          "mark": {
            "type": "text",
            "align": "left",
            "fontSize": 13,
            "fontWeight": "bold",
            "color": "#2b6cb0",
            "cursor": "pointer"
          },
          "encoding": {
            "x": {
              "value": 18
            },
            "y": {
              "value": 318
            },
            "text": {
              "field": "_l",
              "type": "nominal"
            },
            "href": {
              "field": "link",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "name": "loc"
          },
          "transform": [
            {
              "filter": {
                "param": "sel",
                "empty": false
              }
            }
          ],
          "mark": {
            "type": "image",
            "width": 200,
            "aspect": true,
            "align": "left",
