{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "hconcat": [
    {
      "width": 520,
      "height": 640,
      "title": {
        "text": "Le location del CineTourism in Italia",
        "fontSize": 15,
        "anchor": "start"
      },
      "layer": [
        {
          "data": {
            "url": "https://raw.githubusercontent.com/openpolis/geojson-italy/master/topojson/limits_IT_regions.topo.json",
            "format": {
              "type": "topojson",
              "feature": "regions"
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": "#eaeef2",
            "stroke": "white",
            "strokeWidth": 0.6
          },
          "projection": {
            "type": "mercator"
          }
        },
        {
          "data": {
            "name": "loc"
          },
          "projection": {
            "type": "mercator"
          },
          "mark": {
            "type": "circle",
            "stroke": "white",
            "strokeWidth": 1
          },
          "params": [
            {
              "name": "sel",
              "select": {
                "type": "point",
                "fields": [
                  "produzione"
                ],
                "on": "click",
                "clear": "dblclick"
              }
            }
          ],
          "encoding": {
            "longitude": {
              "field": "lon",
              "type": "quantitative"
            },
            "latitude": {
              "field": "lat",
              "type": "quantitative"
            },
            "size": {
              "condition": {
                "param": "sel",
                "empty": false,
                "value": 230
              },
              "value": 95
            },
            "opacity": {
              "condition": {
                "param": "sel",
                "empty": true,
                "value": 1
              },
              "value": 0.45
            },
            "color": {
              "field": "cluster",
              "type": "nominal",
              "scale": {
                "domain": [
                  "Cluster 1",
                  "Cluster 2",
                  "Cluster 3"
                ],
                "range": [
                  "#c05621",
                  "#2b6cb0",
                  "#2f855a"
                ]
              },
              "legend": {
                "title": null,
                "orient": "top-right",
                "fillColor": "white",
                "padding": 8,
                "cornerRadius": 4,
                "offset": 6
              }
            },
            "tooltip": [
              {
                "field": "produzione",
                "type": "nominal",
                "title": "Produzione"
              },
              {
                "field": "localita",
                "type": "nominal",
                "title": "Località"
              },
              {
                "field": "cluster",
                "type": "nominal",
                "title": "Cluster"
              }
            ]
          }
        }
      ]
    },
    {
      "width": 280,
      "height": 640,
      "view": {
        "stroke": null
      },
      "layer": [
        {
          "data": {
            "values": [
              {}
            ]
          },
          "mark": {
            "type": "rect",
            "fill": "#f7f9fb",
            "stroke": "#d9e2ec",
            "cornerRadius": 8
          },
          "encoding": {
            "x": {
              "value": 0
            },
            "x2": {
              "value": 279
            },
            "y": {
              "value": 0
            },
            "y2": {
              "value": 639
            }
          }
        },
        {
          "data": {
            "values": [
              {
                "t": "SCHEDA PRODUZIONE"
              }
            ]
          },
          "mark": {
            "type": "text",
            "align": "left",
            "fontSize": 11,
            "fontWeight": "bold",
            "color": "#94a3b8"
          },
          "encoding": {
            "x": {
              "value": 18
            },
            "y": {
              "value": 26
            },
            "text": {
              "field": "t",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "name": "loc"
          },
          "transform": [
            {
              "filter": {
                "param": "sel",
                "empty": false
              }
            }
          ],
          "mark": {
            "type": "text",
            "align": "left",
            "fontSize": 18,
            "fontWeight": "bold",
            "color": "#1a202c",
            "limit": 250
          },
          "encoding": {
            "x": {
              "value": 18
            },
            "y": {
              "value": 70
            },
            "text": {
              "field": "produzione",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "name": "loc"
          },
          "transform": [
            {
              "filter": {
                "param": "sel",
                "empty": false
              }
            }
          ],
          "mark": {
            "type": "text",
            "align": "left",
            "fontSize": 12,
            "fontWeight": "normal",
            "color": "#777",
            "limit": 250
          },
          "encoding": {
            "x": {
              "value": 18
            },
            "y": {
              "value": 96
            },
            "text": {
              "field": "cluster_label",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "name": "loc"
          },
          "transform": [
            {
              "filter": {
                "param": "sel",
                "empty": false
              }
            },
            {
              "calculate": "'LOCALITÀ DI RIPRESA'",
              "as": "_c"
            }
          ],
          "mark": {
            "type": "text",
            "align": "left",
            "fontSize": 11,
            "fontWeight": "bold",
            "color": "#94a3b8",
            "limit": 250
          },
          "encoding": {
            "x": {
              "value": 18
            },
            "y": {
              "value": 140
            },
            "text": {
              "field": "_c",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "name": "loc"
          },
          "transform": [
            {
              "filter": {
                "param": "sel",
                "empty": false
              }
            },
            {
              "window": [
                {
                  "op": "row_number",
                  "as": "idx"
                }
              ],
              "sort": [
                {
                  "field": "localita",
                  "order": "ascending"
                }
              ]
            },
            {
              "calculate": "'•  ' + datum.localita",
              "as": "bullet"
            }
          ],
          "mark": {
            "type": "text",
            "align": "left",
            "fontSize": 14,
            "color": "#2b6cb0"
          },
          "encoding": {
            "x": {
              "value": 18
            },
            "y": {
              "field": "idx",
              "type": "quantitative",
              "scale": {
                "domain": [
                  0,
                  10
                ],
                "range": [
                  162,
                  482
                ]
              },
              "axis": null
            },
            "text": {
              "field": "bullet",
              "type": "nominal"
            }
          }
        },
        {
          "data": {
            "name": "loc"
          },
          "transform": [
            {
              "filter": {
                "param": "sel",
                "empty": false
              }
            },
            {
              "calculate": "'→  Vai alla pagina del cluster'",
              "as": "_l"
            }
          ],
          "mark": {
            "type": "text",
            "align": "left",
            "fontSize": 13,
            "fontWeight": "bold",
            "color": "#2b6cb0",
            "cursor": "pointer"
          },
          "encoding": {
            "x": {
              "value": 18
            },
            "y": {
              "value": 320
            },
            "text": {
              "field": "_l",
              "type": "nominal"
            },
            "href": {
              "field": "link",
              "type": "nominal"
            }
          }
        }
      ]
    }
  ],
