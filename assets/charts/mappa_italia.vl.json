        "anchor": "start"
      },
      "layer": [
        {
          "data": {
            "url": "https://raw.githubusercontent.com/openpolis/geojson-italy/master/topojson/limits_IT_regions.topo.json",
            "format": {
              "type": "topojson",
              "feature": "regions"
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": "#eaeef2",
            "stroke": "white",
            "strokeWidth": 0.6
          },
          "projection": {
            "type": "mercator"
          }
        },
        {
          "data": {
            "name": "loc"
          },
          "projection": {
            "type": "mercator"
          },
          "mark": {
            "type": "circle",
            "stroke": "white",
            "strokeWidth": 1
          },
          "params": [
            {
              "name": "sel",
              "select": {
                "type": "point",
                "fields": [
                  "localita"
                ],
                "on": "click"
              }
            }
          ],
          "encoding": {
            "longitude": {
              "field": "lon",
              "type": "quantitative"
            },
            "latitude": {
              "field": "lat",
              "type": "quantitative"
            },
            "size": {
              "condition": {
                "param": "sel",
                "empty": false,
                "value": 230
              },
              "value": 95
            },
            "opacity": {
              "condition": {
                "param": "sel",
                "empty": true,
                "value": 1
              },
              "value": 0.5
            },
            "color": {
              "field": "cluster",
              "type": "nominal",
              "scale": {
                "domain": [
                  "Cluster 1",
                  "Cluster 2",
                  "Cluster 3"
                ],
                "range": [
                  "#c05621",
                  "#2b6cb0",
                  "#2f855a"
                ]
              },
              "legend": {
                "title": null,
                "orient": "top-left",
                "fillColor": "white",
                "padding": 6
              }
            },
            "tooltip": [
              {
                "field": "localita",
                "type": "nominal",
                "title": "Località"
              },
              {
                "field": "produzione",
                "type": "nominal",
                "title": "Produzione"
              },
              {
                "field": "cluster",
                "type": "nominal",
                "title": "Cluster"
              }
            ]
          }
        }
      ]
