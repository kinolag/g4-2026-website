{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "hconcat": [
    {
      "width": 520,
      "height": 640,
      "title": {
        "text": "Località del CineTourism in Italia",
        "fontSize": 15,
        "anchor": "start"
      },
      "layer": [
        {
          "data": {
            "url": "https://raw.githubusercontent.com/openpolis/geojson-italy/master/topojson/limits_IT_regions.topo.json",
            "format": {
              "type": "topojson",
              "feature": "regions"
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": "#eaeef2",
            "stroke": "white",
            "strokeWidth": 0.6
          },
          "projection": {
            "type": "mercator"
          }
        },
        {
          "data": {
            "name": "loc"
          },
          "projection": {
            "type": "mercator"
          },
          "mark": {
            "type": "circle",
            "stroke": "white",
            "strokeWidth": 1
          },
          "params": [
            {
              "name": "sel",
              "select": {
                "type": "point",
                "fields": [
                  "produzione"
                ],
                "on": "click",
                "clear": "dblclick"
              }
            }
          ],
          "encoding": {
            "longitude": {
              "field": "lon",
              "type": "quantitative"
            },
            "latitude": {
              "field": "lat",
              "type": "quantitative"
            },
            "size": {
              "condition": {
                "param": "sel",
                "empty": false,
                "value": 230
              },
              "value": 95
            },
            "opacity": {
              "condition": {
                "param": "sel",
                "empty": true,
                "value": 1
              },
              "value": 0.45
            },
            "color": {
              "field": "cluster",
              "type": "nominal",
              "scale": {
                "domain": [
                  "Cluster 1",
                  "Cluster 2",
                  "Cluster 3"
                ],
                "range": [
                  "#c05621",
                  "#2b6cb0",
                  "#2f855a"
                ]
              },
              "legend": {
                "title": null,
                "orient": "top-right",
                "fillColor": "white",
                "padding": 8,
                "cornerRadius": 4,
                "offset": 6
              }
            },
            "tooltip": [
              {
                "field": "produzione",
                "type": "nominal",
                "title": "Produzione"
              },
              {
                "field": "localita",
                "type": "nominal",
                "title": "Località"
              },
              {
                "field": "cluster",
                "type": "nominal",
                "title": "Cluster"
              }
            ]
          }
        }
      ]
    },
    {
      "width": 280,
      "height": 700,
